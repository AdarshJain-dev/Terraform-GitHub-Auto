{
  "aws_region": "us-east-1",

  "ec2_instances": {
    "prasam-ec2": {
      "ami":           "ami-0c02fb55956c7d316",
      "instance_type": "t3.micro",
      "key_name":      "",
      "tags": {
        "Environment": "dev",
        "Role":        "web"
      }
    }
  },
  

  "s3_buckets": {
    "prasamjain-app-uploads": {
      "versioning_enabled": true,
      "force_destroy":      false,
      "tags": {
        "Environment": "dev",
        "Purpose":     "app-uploads"
      }
    }
  },

  "iam_users": {
    "dev-user": {
      "path":        "/",
      "policy_arns": [
        "arn:aws:iam::aws:policy/ReadOnlyAccess"
      ],
      "tags": {
        "Environment": "dev",
        "Team":        "engineering"
      }
    }
  }

}
